{
  "name": "lokizio-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Test suite for Lokizio (unit + integration + E2E)",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:edge": "vitest run tests/edge",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:crawler": "playwright test --project=crawler",
    "test:monkey": "playwright test --project=monkey",
    "test:all": "npm run test && npm run test:e2e",
    "coverage": "vitest run --coverage",
    "audit": "node scripts/audit.js",
    "audit:quick": "node scripts/audit.js --quick",
    "audit:ci": "node scripts/audit.js --ci --quick",
    "audit:strict": "node scripts/audit.js --strict",
    "bump": "node scripts/bump-cache-busters.js",
    "bump:check": "node scripts/bump-cache-busters.js --check",
    "serve": "npx --yes http-server . -p 8000 -c-1 --cors",
    "sentry": "node scripts/fetch-sentry-issues.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@supabase/supabase-js": "^2.104.0",
    "@vitest/coverage-v8": "^2.1.0",
    "dotenv": "^17.4.2",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.0"
  }
}
